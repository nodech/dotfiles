#!/usr/bin/env python3

import argparse
import codecs
import hashlib
import json
import os
import re
import shutil
import subprocess
import sys
from datetime import datetime, timezone
from pathlib import Path


MODEM_ID = os.environ.get("MMCLI_MODEM_ID")
STATE_DIR = Path(os.environ.get("XDG_STATE_HOME", Path.home() / ".local" / "state")) / "mmcli-sms"
STATE_FILE = STATE_DIR / "state.json"
STATE_VERSION = 2
MODEM_LIST_RE = re.compile(r"/Modem/(\d+)")
SMS_ID_RE = re.compile(r"SMS/(\d+)")


def die(message: str) -> "NoReturn":
    print(f"error: {message}", file=sys.stderr)
    raise SystemExit(1)


def run_mmcli(*args: str) -> str:
    try:
        proc = subprocess.run(
            ["mmcli", *args],
            check=True,
            text=True,
            capture_output=True,
        )
    except FileNotFoundError:
        die("missing required command: mmcli")
    except subprocess.CalledProcessError as exc:
        stderr = exc.stderr.strip()
        stdout = exc.stdout.strip()
        die(stderr or stdout or f"mmcli failed: {' '.join(args)}")
    return proc.stdout


def ensure_state_dir() -> None:
    STATE_DIR.mkdir(parents=True, exist_ok=True)


def get_modem_id() -> str:
    if MODEM_ID:
        return MODEM_ID

    output = run_mmcli("-L")
    modem_ids = sorted(set(MODEM_LIST_RE.findall(output)), key=int)
    if not modem_ids:
        die("no modems found")
    if len(modem_ids) > 1:
        die(f"multiple modems found ({', '.join(modem_ids)}); set MMCLI_MODEM_ID")
    return modem_ids[0]


def empty_state() -> dict:
    return {
        "version": STATE_VERSION,
        "seen_keys": [],
        "messages": {},
        "legacy_seen_ids": [],
        "legacy_sent_times": {},
    }


def normalize_message_record(record: dict) -> dict[str, str | list[str] | bool]:
    ids = record.get("ids", [])
    if not isinstance(ids, list):
        ids = []
    return {
        "direction": str(record.get("direction", "unknown")),
        "number": str(record.get("number", "unknown")),
        "text": str(record.get("text", "")),
        "timestamp": str(record.get("timestamp", "")),
        "discharge_timestamp": str(record.get("discharge_timestamp", "")),
        "ids": [str(item) for item in ids],
        "local": bool(record.get("local", False)),
    }


def load_state() -> dict:
    ensure_state_dir()
    if not STATE_FILE.exists():
        return empty_state()

    try:
        data = json.loads(STATE_FILE.read_text())
    except json.JSONDecodeError:
        return empty_state()

    state = empty_state()

    seen_keys = data.get("seen_keys", [])
    if isinstance(seen_keys, list):
        state["seen_keys"] = [str(item) for item in seen_keys]

    messages = data.get("messages", {})
    if isinstance(messages, dict):
        state["messages"] = {
            str(key): normalize_message_record(record)
            for key, record in messages.items()
            if isinstance(record, dict)
        }

    legacy_seen_ids = data.get("seen_ids", [])
    if isinstance(legacy_seen_ids, list):
        state["legacy_seen_ids"] = [str(item) for item in legacy_seen_ids]

    legacy_sent_times = data.get("sent_times", {})
    if isinstance(legacy_sent_times, dict):
        state["legacy_sent_times"] = {str(key): str(value) for key, value in legacy_sent_times.items()}

    return state


def save_state(state: dict) -> None:
    ensure_state_dir()

    seen_keys = sorted(set(str(item) for item in state.get("seen_keys", [])))
    messages = state.get("messages", {})
    if not isinstance(messages, dict):
        messages = {}

    normalized_messages = {
        str(key): normalize_message_record(record)
        for key, record in messages.items()
        if isinstance(record, dict)
    }

    sorted_messages = dict(
        sorted(
            normalized_messages.items(),
            key=lambda item: (
                str(item[1].get("timestamp", "")),
                str(item[1].get("number", "")),
                str(item[1].get("text", "")),
                item[0],
            ),
        )
    )

    payload = {
        "version": STATE_VERSION,
        "seen_keys": seen_keys,
        "messages": sorted_messages,
    }
    STATE_FILE.write_text(json.dumps(payload, indent=2) + "\n")


def list_sms_ids() -> list[str]:
    output = run_mmcli("-m", get_modem_id(), "--messaging-list-sms")
    ids = SMS_ID_RE.findall(output)
    return sorted(set(ids), key=int)


def parse_kv_fields(output: str) -> dict[str, str]:
    fields: dict[str, str] = {}
    for line in output.splitlines():
        stripped = line.strip()
        if ":" not in stripped:
            continue
        key, value = stripped.split(":", 1)
        fields[key.strip()] = value.strip()
    return fields


def sms_details(sms_id: str) -> dict[str, str]:
    output = run_mmcli("-K", "-s", sms_id)
    data = parse_kv_fields(output)
    return {
        "id": sms_id,
        "pdu_type": data.get("sms.properties.pdu-type", "unknown-type"),
        "state": data.get("sms.properties.state", "unknown-state"),
        "number": data.get("sms.content.number", "unknown"),
        "text": decode_sms_text(data.get("sms.content.text", "")),
        "timestamp": data.get("sms.properties.timestamp", "unknown-time"),
        "discharge_timestamp": data.get("sms.properties.discharge-timestamp", ""),
    }


def decode_sms_text(value: str) -> str:
    if "\\" not in value:
        return value

    try:
        unescaped = codecs.decode(value, "unicode_escape")
    except Exception:
        return value

    try:
        return unescaped.encode("latin1").decode("utf-8")
    except Exception:
        return unescaped


def normalize_number(value: str) -> str:
    return "".join(value.split())


def quote_mmcli_value(value: str) -> str:
    escaped = value.replace("\\", "\\\\").replace('"', '\\"')
    return f'"{escaped}"'


def compact_text(value: str) -> str:
    return " ".join(value.split()) or "<empty>"


def truncate_text(value: str, width: int) -> str:
    if width <= 0:
        return ""
    if len(value) <= width:
        return value
    if width == 1:
        return value[:1]
    return value[: width - 1] + "…"


def sanitize_completion_field(value: str) -> str:
    return " ".join(value.split()).replace("\t", " ")


def sms_direction(details: dict[str, str]) -> str:
    pdu_type = details.get("pdu_type", "")
    if pdu_type == "deliver":
        return "recv"
    if pdu_type == "submit":
        return "sent"
    if pdu_type == "status-report":
        return "report"
    return pdu_type or "unknown"


def current_time_iso() -> str:
    return datetime.now(timezone.utc).isoformat(timespec="seconds").replace("+00:00", "Z")


def canonical_timestamp(value: str) -> str:
    if not value or value == "unknown-time":
        return ""
    return value


def resolve_message_timestamp(details: dict[str, str], fallback_timestamp: str = "") -> str:
    return canonical_timestamp(details.get("timestamp", "")) or canonical_timestamp(
        details.get("discharge_timestamp", "")
    ) or canonical_timestamp(fallback_timestamp)


def make_message_key(direction: str, number: str, text: str, timestamp: str) -> str:
    fingerprint = json.dumps(
        {
            "direction": direction,
            "number": normalize_number(number),
            "text": text,
            "timestamp": timestamp,
        },
        sort_keys=True,
        ensure_ascii=False,
        separators=(",", ":"),
    )
    return hashlib.sha1(fingerprint.encode("utf-8")).hexdigest()[:16]


def find_message_key_by_id(state: dict, sms_id: str) -> str | None:
    for key, record in state.get("messages", {}).items():
        ids = record.get("ids", [])
        if isinstance(ids, list) and sms_id in ids:
            return str(key)
    return None


def find_matching_message_key(state: dict, details: dict[str, str], sms_id: str = "", fallback_timestamp: str = "") -> str | None:
    if sms_id:
        existing_key = find_message_key_by_id(state, sms_id)
        if existing_key:
            return existing_key

    direction = sms_direction(details)
    number = normalize_number(details.get("number", "unknown"))
    text = details.get("text", "")
    timestamp = resolve_message_timestamp(details, fallback_timestamp)

    if timestamp:
        exact_key = make_message_key(direction, number, text, timestamp)
        if exact_key in state.get("messages", {}):
            return exact_key

    if direction == "sent":
        candidates: list[tuple[str, str]] = []
        for key, record in state.get("messages", {}).items():
            if record.get("direction") != "sent":
                continue
            if normalize_number(str(record.get("number", ""))) != number:
                continue
            if str(record.get("text", "")) != text:
                continue
            candidates.append((str(record.get("timestamp", "")), str(key)))
        if len(candidates) == 1:
            return candidates[0][1]
        if candidates:
            candidates.sort()
            return candidates[-1][1]

    return None


def upsert_message(
    state: dict,
    details: dict[str, str],
    *,
    sms_id: str = "",
    fallback_timestamp: str = "",
    local: bool = False,
) -> tuple[str, dict, bool]:
    key = find_matching_message_key(state, details, sms_id=sms_id, fallback_timestamp=fallback_timestamp)
    direction = sms_direction(details)
    timestamp = resolve_message_timestamp(details, fallback_timestamp)
    if not key:
        key = make_message_key(direction, details.get("number", "unknown"), details.get("text", ""), timestamp)

    existing = state.setdefault("messages", {}).get(key, {})
    record = normalize_message_record(existing if isinstance(existing, dict) else {})
    changed = False

    updates = {
        "direction": direction,
        "number": normalize_number(details.get("number", "unknown")),
        "text": details.get("text", ""),
        "timestamp": timestamp,
        "discharge_timestamp": canonical_timestamp(details.get("discharge_timestamp", "")),
        "local": bool(record.get("local", False) or local),
    }
    for field, value in updates.items():
        if record.get(field) != value:
            record[field] = value
            changed = True

    ids = record.get("ids", [])
    if not isinstance(ids, list):
        ids = []
        changed = True
    if sms_id and sms_id not in ids:
        ids.append(sms_id)
        changed = True
    record["ids"] = ids

    if state["messages"].get(key) != record:
        state["messages"][key] = record
        changed = True

    return key, record, changed


def is_seen_key(state: dict, message_key: str) -> bool:
    return message_key in state.get("seen_keys", [])


def mark_seen_key(state: dict, message_key: str) -> bool:
    seen_keys = state.setdefault("seen_keys", [])
    if message_key not in seen_keys:
        seen_keys.append(message_key)
        return True
    return False


def mark_unseen_key(state: dict, message_key: str) -> bool:
    seen_keys = state.get("seen_keys", [])
    if message_key in seen_keys:
        state["seen_keys"] = [item for item in seen_keys if item != message_key]
        return True
    return False


def sms_when(record: dict[str, str | list[str] | bool]) -> str:
    timestamp = str(record.get("timestamp", ""))
    if timestamp:
        return timestamp
    discharge_timestamp = str(record.get("discharge_timestamp", ""))
    if discharge_timestamp:
        return discharge_timestamp
    return "-"


def build_row(record: dict, display_id: str, seen: bool) -> dict[str, str]:
    return {
        "direction": str(record.get("direction", "unknown")),
        "status": "read" if seen else "unread",
        "id": display_id,
        "timestamp": sms_when(record),
        "number": str(record.get("number", "unknown")),
        "text": compact_text(str(record.get("text", ""))),
    }


def include_row(row: dict[str, str], unread_only: bool, status_filter: str) -> bool:
    if unread_only and row["status"] == "read":
        return False
    if status_filter == "read" and row["status"] != "read":
        return False
    if status_filter == "unread" and row["status"] != "unread":
        return False
    return True


def build_summary_rows(
    state: dict, unread_only: bool, reverse_order: bool, status_filter: str = "all"
) -> tuple[list[dict[str, str]], bool]:
    rows: list[dict[str, str]] = []
    state_changed = False
    current_keys: set[str] = set()

    sms_ids = list_sms_ids()
    if not reverse_order:
        sms_ids.reverse()

    for sms_id in sms_ids:
        details = sms_details(sms_id)
        fallback_timestamp = state.get("legacy_sent_times", {}).get(sms_id, "") if sms_direction(details) == "sent" else ""
        message_key, record, changed = upsert_message(
            state,
            details,
            sms_id=sms_id,
            fallback_timestamp=fallback_timestamp,
        )
        state_changed = state_changed or changed
        if sms_id in state.get("legacy_seen_ids", []) and mark_seen_key(state, message_key):
            state_changed = True
        current_keys.add(message_key)
        row = build_row(record, sms_id, is_seen_key(state, message_key))
        if include_row(row, unread_only, status_filter):
            rows.append(row)

    archived_sent_rows: list[dict[str, str]] = []
    for message_key, record in state.get("messages", {}).items():
        if message_key in current_keys:
            continue
        if record.get("direction") != "sent" or not record.get("local", False):
            continue
        row = build_row(record, "-", True)
        if include_row(row, unread_only, status_filter):
            archived_sent_rows.append(row)

    archived_sent_rows.sort(key=lambda row: row["timestamp"], reverse=not reverse_order)
    rows.extend(archived_sent_rows)

    return rows, state_changed


def print_summary_table(rows: list[dict[str, str]]) -> None:
    headers = {
        "direction": "DIR",
        "status": "STATUS",
        "id": "ID",
        "timestamp": "WHEN",
        "number": "FROM",
        "text": "TEXT",
    }
    terminal_width = shutil.get_terminal_size(fallback=(120, 24)).columns
    fixed_widths = {
        "direction": max(len(headers["direction"]), max((len(row["direction"]) for row in rows), default=0)),
        "status": max(len(headers["status"]), max((len(row["status"]) for row in rows), default=0)),
        "id": max(len(headers["id"]), max((len(row["id"]) for row in rows), default=0)),
        "timestamp": max(len(headers["timestamp"]), max((len(row["timestamp"]) for row in rows), default=0)),
        "number": max(len(headers["number"]), max((len(row["number"]) for row in rows), default=0)),
    }
    spacing = 2
    fixed_total = sum(fixed_widths.values()) + (spacing * 5)
    text_width = max(len(headers["text"]), terminal_width - fixed_total)

    print(
        f"{headers['direction']:<{fixed_widths['direction']}}"
        f"{' ' * spacing}"
        f"{headers['status']:<{fixed_widths['status']}}"
        f"{' ' * spacing}"
        f"{headers['id']:<{fixed_widths['id']}}"
        f"{' ' * spacing}"
        f"{headers['timestamp']:<{fixed_widths['timestamp']}}"
        f"{' ' * spacing}"
        f"{headers['number']:<{fixed_widths['number']}}"
        f"{' ' * spacing}"
        f"{headers['text']}"
    )
    print(
        f"{'-' * fixed_widths['direction']}"
        f"{' ' * spacing}"
        f"{'-' * fixed_widths['status']}"
        f"{' ' * spacing}"
        f"{'-' * fixed_widths['id']}"
        f"{' ' * spacing}"
        f"{'-' * fixed_widths['timestamp']}"
        f"{' ' * spacing}"
        f"{'-' * fixed_widths['number']}"
        f"{' ' * spacing}"
        f"{'-' * max(len(headers['text']), min(text_width, 20))}"
    )
    for row in rows:
        print(
            f"{row['direction']:<{fixed_widths['direction']}}"
            f"{' ' * spacing}"
            f"{row['status']:<{fixed_widths['status']}}"
            f"{' ' * spacing}"
            f"{row['id']:<{fixed_widths['id']}}"
            f"{' ' * spacing}"
            f"{row['timestamp']:<{fixed_widths['timestamp']}}"
            f"{' ' * spacing}"
            f"{row['number']:<{fixed_widths['number']}}"
            f"{' ' * spacing}"
            f"{truncate_text(row['text'], text_width)}"
        )


def cmd_complete_ids(args: argparse.Namespace) -> None:
    state = load_state()
    rows, state_changed = build_summary_rows(state, unread_only=False, reverse_order=False, status_filter=args.status)
    if state_changed:
        save_state(state)
    for row in rows:
        if row["id"] == "-":
            continue
        preview = truncate_text(row["text"], 10)
        print(
            "\t".join(
                [
                    sanitize_completion_field(row["id"]),
                    sanitize_completion_field(row["status"]),
                    sanitize_completion_field(row["number"]),
                    sanitize_completion_field(row["timestamp"]),
                    sanitize_completion_field(preview),
                ]
            )
        )


def cmd_list(args: argparse.Namespace) -> None:
    state = load_state()
    rows, state_changed = build_summary_rows(state, args.status == "unread", args.reverse, status_filter=args.status)
    if state_changed:
        save_state(state)
    if not rows:
        if not args.no_header:
            print("No unread SMS." if args.status == "unread" else "No read SMS." if args.status == "read" else "No SMS found.")
        return
    if args.no_header:
        for row in rows:
            print(
                "\t".join(
                    [
                        row["direction"],
                        row["status"],
                        row["id"],
                        row["timestamp"],
                        row["number"],
                        row["text"],
                    ]
                )
            )
        return
    print_summary_table(rows)


def cmd_read(args: argparse.Namespace) -> None:
    state = load_state()
    details = sms_details(args.id)
    fallback_timestamp = state.get("legacy_sent_times", {}).get(args.id, "") if sms_direction(details) == "sent" else ""
    message_key, record, changed = upsert_message(
        state,
        details,
        sms_id=args.id,
        fallback_timestamp=fallback_timestamp,
    )
    if args.id in state.get("legacy_seen_ids", []) and mark_seen_key(state, message_key):
        changed = True
    seen = "yes" if is_seen_key(state, message_key) else "no"

    print(f"SMS {args.id}")
    print(f"Type:  {sms_direction(details)}")
    print(f"State: {details.get('state', 'unknown-state')}")
    print(f"Seen:  {seen}")
    print(f"From:  {details.get('number', 'unknown')}")
    print(f"When:  {sms_when(record)}")
    print()
    print(details.get("text", ""))

    if args.mark_seen:
        changed = mark_seen_key(state, message_key) or changed
    if changed:
        save_state(state)


def resolve_message_key_for_id(state: dict, sms_id: str) -> str:
    details = sms_details(sms_id)
    fallback_timestamp = state.get("legacy_sent_times", {}).get(sms_id, "") if sms_direction(details) == "sent" else ""
    message_key, _, changed = upsert_message(state, details, sms_id=sms_id, fallback_timestamp=fallback_timestamp)
    if sms_id in state.get("legacy_seen_ids", []) and mark_seen_key(state, message_key):
        changed = True
    if changed:
        save_state(state)
    return message_key


def cmd_seen(args: argparse.Namespace) -> None:
    state = load_state()
    message_key = resolve_message_key_for_id(state, args.id)
    if mark_seen_key(state, message_key):
        save_state(state)
    print(f"Marked SMS {args.id} as seen.")


def cmd_unseen(args: argparse.Namespace) -> None:
    state = load_state()
    message_key = resolve_message_key_for_id(state, args.id)
    if mark_unseen_key(state, message_key):
        save_state(state)
    print(f"Marked SMS {args.id} as unseen.")


def cmd_send(args: argparse.Namespace) -> None:
    state = load_state()
    modem_id = get_modem_id()
    number = normalize_number(args.number)
    sent_timestamp = current_time_iso()
    properties = ",".join(
        [
            f"text={quote_mmcli_value(args.text)}",
            f"number={quote_mmcli_value(number)}",
        ]
    )
    create_output = run_mmcli(
        "-m",
        modem_id,
        f"--messaging-create-sms={properties}",
    )
    match = SMS_ID_RE.search(create_output)
    if not match:
        die("failed to parse created SMS id")
    sms_id = match.group(1)
    run_mmcli("-s", sms_id, "--send")

    details = {
        "id": sms_id,
        "pdu_type": "submit",
        "state": "sent",
        "number": number,
        "text": args.text,
        "timestamp": sent_timestamp,
        "discharge_timestamp": "",
    }
    message_key, _, _ = upsert_message(
        state,
        details,
        sms_id=sms_id,
        fallback_timestamp=sent_timestamp,
        local=True,
    )
    mark_seen_key(state, message_key)
    save_state(state)
    print(f"Sent SMS {sms_id} to {number}.")


def cmd_raw(args: argparse.Namespace) -> None:
    print(run_mmcli("-s", args.id), end="")


def build_parser() -> argparse.ArgumentParser:
    parser = argparse.ArgumentParser(
        prog="sms",
        description="Inspect and send SMS messages via ModemManager (mmcli).",
        epilog=(
            "Examples:\n"
            "  sms               List SMS messages\n"
            "  sms list --unread List only unread messages\n"
            "  sms read 12       Show SMS 12\n"
            "  sms send +15551234567 'hello'"
        ),
        formatter_class=argparse.RawDescriptionHelpFormatter,
    )
    sub = parser.add_subparsers(
        dest="command",
        required=True,
        metavar="{list,ls,read,show,seen,unseen,send,raw}",
    )

    p_list = sub.add_parser(
        "list",
        aliases=["ls"],
        help="List SMS messages",
        description="List SMS messages known to the modem.",
    )
    status_group = p_list.add_mutually_exclusive_group()
    status_group.add_argument(
        "--unread",
        action="store_const",
        const="unread",
        dest="status",
        help="Show only unread SMS messages",
    )
    status_group.add_argument(
        "--read",
        action="store_const",
        const="read",
        dest="status",
        help="Show only read SMS messages",
    )
    p_list.set_defaults(status="all")
    p_list.add_argument(
        "--reverse",
        action="store_true",
        help="Reverse the default newest-first order",
    )
    p_list.add_argument(
        "--no-header",
        action="store_true",
        help="Print rows without table headers, using tab-separated columns",
    )
    p_list.set_defaults(func=cmd_list)

    p_read = sub.add_parser(
        "read",
        aliases=["show"],
        help="Read a message",
        description="Show details for a single SMS message.",
    )
    p_read.add_argument("id", metavar="ID", help="SMS ID")
    p_read.add_argument("--mark-seen", action="store_true", help="Mark the message as seen after reading")
    p_read.set_defaults(func=cmd_read)

    p_seen = sub.add_parser(
        "seen",
        help="Mark a message as seen",
        description="Mark an SMS message as seen in local state.",
    )
    p_seen.add_argument("id", metavar="ID", help="SMS ID")
    p_seen.set_defaults(func=cmd_seen)

    p_unseen = sub.add_parser(
        "unseen",
        help="Mark a message as unread",
        description="Mark an SMS message as unread in local state.",
    )
    p_unseen.add_argument("id", metavar="ID", help="SMS ID")
    p_unseen.set_defaults(func=cmd_unseen)

    p_send = sub.add_parser(
        "send",
        help="Send a message",
        description="Create and send an SMS message.",
    )
    p_send.add_argument("number", metavar="NUMBER", help="Destination phone number")
    p_send.add_argument("text", metavar="TEXT", help="Message body")
    p_send.set_defaults(func=cmd_send)

    p_raw = sub.add_parser(
        "raw",
        help="Show raw mmcli output",
        description="Show the raw mmcli output for a single SMS message.",
    )
    p_raw.add_argument("id", metavar="ID", help="SMS ID")
    p_raw.set_defaults(func=cmd_raw)

    p_complete_ids = sub.add_parser("complete-ids", help=argparse.SUPPRESS)
    p_complete_ids.add_argument(
        "--status",
        choices=["all", "read", "unread"],
        default="all",
        help=argparse.SUPPRESS,
    )
    p_complete_ids.set_defaults(func=cmd_complete_ids)
    sub._choices_actions = [action for action in sub._choices_actions if action.dest != "complete-ids"]

    return parser


def main() -> None:
    parser = build_parser()
    argv = sys.argv[1:] or ["list"]
    args = parser.parse_args(argv)
    args.func(args)


if __name__ == "__main__":
    main()
